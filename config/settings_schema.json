[
  {
    "name": "theme_info",
    "theme_name": "Aperture Commerce",
    "theme_version": "2.1.0",
    "theme_author": "Antigravity",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "social_sharing_image",
        "label": "Social sharing image"
      },
      {
        "type": "textarea",
        "id": "seo_default_description",
        "label": "Default meta description",
        "default": "A polished, high-converting Shopify storefront with strong performance, SEO foundations, and flexible sections for merchandising."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#123b38"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#d46f4d"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background color",
        "default": "#f8f1e7"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface color",
        "default": "#fffdf8"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color",
        "default": "#181714"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text color",
        "default": "#6f675e"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#d8cfbf"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_width",
        "label": "Container width",
        "min": 1080,
        "max": 1600,
        "step": 20,
        "default": 1280,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Vertical section spacing",
        "min": 40,
        "max": 140,
        "step": 4,
        "default": 84,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "card_radius",
        "label": "Card corner radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "default": 28,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "button_radius",
        "label": "Button corner radius",
        "min": 0,
        "max": 999,
        "step": 3,
        "default": 999,
        "unit": "px"
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_header",
        "label": "Enable sticky header",
        "default": true
      }
    ]
  },
  {
    "name": "Social links",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_x_link",
        "label": "X / Twitter"
      }
    ]
  }
]
