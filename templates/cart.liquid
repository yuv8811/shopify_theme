<div class="cart-page page-width">
  <h1>Your Cart</h1>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
      <table class="cart-table">
        <thead>
          <tr>
            <th colspan="2">Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr class="cart-item">
              <!-- Item Image -->
              <td class="cart-item__image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title | escape }}" width="100" height="100">
                  </a>
                {%- endif -%}
              </td>

              <!-- Item Details -->
              <td class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="cart-item__options">{{ item.variant.title }}</div>
                {%- endunless -%}
                <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" class="cart-item__remove">Remove</a>
              </td>

              <!-- Price -->
              <td class="cart-item__price">
                {{ item.price | money }}
              </td>

              <!-- Quantity -->
              <td class="cart-item__quantity">
                <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.title | escape }}">
              </td>

              <!-- Line Price -->
              <td class="cart-item__line-price">
                {{ item.final_line_price | money }}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <!-- Subtotal and Actions -->
      <div class="cart-footer">
        <div class="cart-subtotal">
          <span class="subtotal-label">Subtotal:</span>
          <span class="subtotal-price">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-shipping-note">Taxes and shipping calculated at checkout.</p>

        <div class="cart-actions">
          <button type="submit" name="update" class="btn btn--secondary">Update Cart</button>
          <button type="submit" name="checkout" class="btn btn--primary">Checkout</button>
        </div>
      </div>
    </form>
  {%- else -%}
    <div class="cart-empty">
      <p>Your cart is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Continue Shopping</a>
    </div>
  {%- endif -%}
</div>
