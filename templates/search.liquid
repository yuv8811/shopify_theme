{%- paginate search.results by 12 -%}
<div class="search-page page-width">
  <header class="search-header text-center">
    <h1>Search Results</h1>
    
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form-inline">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search our store..." aria-label="Search">
      <button type="submit" class="btn btn--primary">Search</button>
    </form>
  </header>

  {%- if search.performed -%}
    <div class="search-results-meta">
      <p>Your search for "{{ search.terms }}" returned {{ search.results_count }} results.</p>
    </div>

    {%- if search.results_count > 0 -%}
      <div class="product-grid">
        {%- for item in search.results -%}
          <!-- Check if it is a product before showing ecommerce features -->
          {%- if item.object_type == 'product' -%}
            <div class="product-card">
              <a href="{{ item.url }}" class="product-card__link">
                <div class="product-card__image-wrapper">
                  {%- if item.featured_image -%}
                    <img src="{{ item.featured_image | image_url: width: 300 }}" 
                         alt="{{ item.featured_image.alt | escape }}" 
                         loading="lazy" 
                         width="300"
                         height="{{ 300 | divided_by: item.featured_image.aspect_ratio | round }}">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                <h2 class="product-card__title">{{ item.title }}</h2>
                <div class="product-card__price">
                  <span>{{ item.price | money }}</span>
                </div>
              </a>
            </div>
          {%- else -%}
            <!-- Fallback generic page or article result card -->
            <div class="generic-card">
              <a href="{{ item.url }}">
                <h2 class="generic-card__title">{{ item.title }}</h2>
                <p class="generic-card__excerpt">{{ item.content | strip_html | truncatewords: 20 }}</p>
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
</div>
{%- endpaginate -%}
