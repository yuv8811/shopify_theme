{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_image = current_variant.featured_image | default: product.featured_image -%}

<div class="product-page page-width">
  <div class="product-grid">
    <!-- Product Media -->
    <div class="product-media">
      {%- if featured_image -%}
        <img src="{{ featured_image | image_url: width: 600 }}" 
             id="ProductPhotoImg" 
             alt="{{ featured_image.alt | escape }}" 
             width="600" 
             height="{{ 600 | divided_by: featured_image.aspect_ratio | round }}">
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      {%- if product.images.size > 1 -%}
        <div class="product-thumbnails">
          {%- for image in product.images -%}
            <a href="{{ image | image_url: width: 600 }}" class="product-thumbnail-link">
              <img src="{{ image | image_url: width: 100 }}" alt="{{ image.alt | escape }}" width="100" height="100">
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product Info Form -->
    <div class="product-info">
      <h1 class="product-title">{{ product.title }}</h1>
      <div class="product-vendor">{{ product.vendor }}</div>

      <div class="product-price-wrapper">
        <span class="product-price" id="ProductPrice">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="compare-price" id="ComparePrice">{{ current_variant.compare_at_price | money }}</s>
        {%- endif -%}
      </div>

      {%- form 'product', product, class: 'product-form' -%}
        <!-- Variant Selectors -->
        {%- unless product.has_only_default_variant -%}
          <div class="product-options">
            {%- for option in product.options_with_values -%}
              <div class="product-option-item">
                <label for="Option-{{ option.name | handleize }}">{{ option.name }}</label>
                <select id="Option-{{ option.name | handleize }}" class="option-selector" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <!-- Master Variant Selector (Hidden) -->
        <select name="id" id="ProductSelect" class="product-select-hidden" style="display:none;">
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}" 
                    {% if variant == current_variant %}selected="selected"{% endif %}
                    {% unless variant.available %}disabled="disabled"{% endunless %}
                    data-price="{{ variant.price }}"
                    data-compare-at-price="{{ variant.compare_at_price }}">
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {%- endfor -%}
        </select>

        <!-- Quantity Selector -->
        <div class="product-quantity">
          <label for="Quantity">Quantity</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1">
        </div>

        <!-- Submit Button -->
        <button type="submit" name="add" id="AddToCart" class="btn btn--primary" {% unless current_variant.available %}disabled="disabled"{% endunless %}>
          <span id="AddToCartText">
            {%- if current_variant.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </span>
        </button>
      {%- endform -%}

      <div class="product-description rte">
        {{ product.description }}
      </div>
    </div>
  </div>
</div>

<script>
  // Simple variant switching logic
  document.addEventListener('DOMContentLoaded', () => {
    const optionSelectors = document.querySelectorAll('.option-selector');
    const masterSelect = document.getElementById('ProductSelect');
    
    if (optionSelectors.length > 0 && masterSelect) {
      const variants = [
        {%- for variant in product.variants -%}
          {
            id: {{ variant.id }},
            title: {{ variant.title | json }},
            options: [{{ variant.option1 | json }}, {{ variant.option2 | json }}, {{ variant.option3 | json }}],
            available: {{ variant.available }},
            price: "{{ variant.price | money }}",
            comparePrice: {% if variant.compare_at_price %}"{{ variant.compare_at_price | money }}"{% else %}null{% endif %},
            featuredImage: {% if variant.featured_image %}"{{ variant.featured_image | image_url: width: 600 }}"{% else %}null{% endif %}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ];

      function updateVariant() {
        const selectedOptions = Array.from(optionSelectors).map(select => select.value);
        const matchedVariant = variants.find(variant => {
          return variant.options.every((opt, idx) => {
            return opt === null || opt === selectedOptions[idx];
          });
        });

        if (matchedVariant) {
          masterSelect.value = matchedVariant.id;
          
          // Update Price
          document.getElementById('ProductPrice').textContent = matchedVariant.price;
          const comparePriceEl = document.getElementById('ComparePrice');
          if (comparePriceEl) {
            if (matchedVariant.comparePrice) {
              comparePriceEl.textContent = matchedVariant.comparePrice;
              comparePriceEl.style.display = 'inline';
            } else {
              comparePriceEl.style.display = 'none';
            }
          }

          // Update Add to Cart Button
          const btn = document.getElementById('AddToCart');
          const btnText = document.getElementById('AddToCartText');
          if (matchedVariant.available) {
            btn.removeAttribute('disabled');
            btnText.textContent = 'Add to Cart';
          } else {
            btn.setAttribute('disabled', 'disabled');
            btnText.textContent = 'Sold Out';
          }

          // Update Image if variant image exists
          if (matchedVariant.featuredImage) {
            document.getElementById('ProductPhotoImg').src = matchedVariant.featuredImage;
          }
        }
      }

      optionSelectors.forEach(select => select.addEventListener('change', updateVariant));
    }

    // Thumbnail click handler
    document.querySelectorAll('.product-thumbnail-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('ProductPhotoImg').src = link.href;
      });
    });
  });
</script>
