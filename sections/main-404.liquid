<section class="section">
  <div class="page-width">
    <div class="page-shell" style="max-width: 44rem; margin-inline:auto; text-align:center;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p class="muted">{{ section.settings.text }}</p>
      <div class="button-row" style="justify-content:center;">
        <a class="btn btn--primary" href="{{ routes.root_url }}">{{ section.settings.primary_label }}</a>
        <a class="btn btn--secondary" href="{{ routes.search_url }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main 404",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The page you're looking for no longer lives here."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Use this page to gently redirect shoppers back into search or your main catalog."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Return home"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Search the store"
    }
  ],
  "presets": [
    {
      "name": "Main 404"
    }
  ]
}
{% endschema %}
