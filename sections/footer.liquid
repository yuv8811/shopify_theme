<footer class="footer">
  <div class="page-width">
    <div class="footer__layout">
      <div class="footer__brand">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading | default: shop.name }}</h2>
        {% if section.settings.text != blank %}
          <div class="rte">{{ section.settings.text }}</div>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu' %}
            <div class="footer__menu" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.heading }}</h3>
              {% if block.settings.menu != blank %}
                <ul class="footer-menu">
                  {% for link in block.settings.menu.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'text' %}
            <div class="footer__menu" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.heading }}</h3>
              {% if block.settings.text != blank %}
                <div class="rte">{{ block.settings.text }}</div>
              {% endif %}
            </div>

          {% when 'newsletter' %}
            <div class="footer__menu" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.heading }}</h3>
              {% if block.settings.text != blank %}
                <p class="muted">{{ block.settings.text }}</p>
              {% endif %}

              {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {% if form.errors %}
                  <div class="form-status form-status--error">{{ form.errors | default_errors }}</div>
                {% endif %}
                {% if form.posted_successfully? %}
                  <p class="form-status form-status--success">Thanks for subscribing.</p>
                {% endif %}
                <div class="newsletter-form__row">
                  <input
                    class="field"
                    type="email"
                    name="contact[email]"
                    value="{{ form.email }}"
                    placeholder="Email address"
                    autocorrect="off"
                    autocapitalize="off"
                    required
                  >
                  <button class="btn btn--primary" type="submit">{{ block.settings.button_label }}</button>
                </div>
              {% endform %}
            </div>

          {% when 'social' %}
            <div class="footer__social" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.heading }}</h3>
              <ul>
                {% if settings.social_instagram_link != blank %}<li><a href="{{ settings.social_instagram_link }}">Instagram</a></li>{% endif %}
                {% if settings.social_facebook_link != blank %}<li><a href="{{ settings.social_facebook_link }}">Facebook</a></li>{% endif %}
                {% if settings.social_youtube_link != blank %}<li><a href="{{ settings.social_youtube_link }}">YouTube</a></li>{% endif %}
                {% if settings.social_tiktok_link != blank %}<li><a href="{{ settings.social_tiktok_link }}">TikTok</a></li>{% endif %}
                {% if settings.social_x_link != blank %}<li><a href="{{ settings.social_x_link }}">X / Twitter</a></li>{% endif %}
              </ul>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span>{{ powered_by_link }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "shopify-section-footer",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Built for modern commerce"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A premium storefront foundation"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use the footer to reinforce your value proposition, share support details, and collect subscribers without slowing the storefront down.</p>"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share shipping times, returns support, or physical showroom details here.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay in the loop"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Launches, editorial stories, and conversion-friendly offers."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Follow"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "menu"
        },
        {
          "type": "menu"
        },
        {
          "type": "newsletter"
        }
      ]
    }
  ]
}
{% endschema %}
