<section class="section">
  <div class="page-width">
    <div class="contact-form__layout">
      <div class="contact-form__details">
        {% if section.settings.eyebrow != blank %}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.text != blank %}
          <div class="rte">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.email != blank %}
          <div class="contact-form__item">
            <strong>Email</strong>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </div>
        {% endif %}
        {% if section.settings.phone != blank %}
          <div class="contact-form__item">
            <strong>Phone</strong>
            <a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a>
          </div>
        {% endif %}
        {% if section.settings.address != blank %}
          <div class="contact-form__item">
            <strong>Address</strong>
            <div class="rte">{{ section.settings.address }}</div>
          </div>
        {% endif %}
      </div>

      <div class="contact-form__panel">
        {% form 'contact', class: 'contact-form__fields' %}
          {% if form.posted_successfully? %}
            <p class="form-status form-status--success">Your message has been sent.</p>
          {% endif %}
          {% if form.errors %}
            <div class="form-status form-status--error">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="product-form__group">
            <label for="ContactFormName-{{ section.id }}">Name</label>
            <input id="ContactFormName-{{ section.id }}" class="field" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
          </div>

          <div class="product-form__group">
            <label for="ContactFormEmail-{{ section.id }}">Email</label>
            <input
              id="ContactFormEmail-{{ section.id }}"
              class="field"
              type="email"
              name="contact[email]"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              autocorrect="off"
              autocapitalize="off"
              required
            >
          </div>

          <div class="product-form__group">
            <label for="ContactFormPhone-{{ section.id }}">Phone</label>
            <input id="ContactFormPhone-{{ section.id }}" class="field" type="tel" name="contact[phone]" value="{{ form.phone }}">
          </div>

          <div class="product-form__group">
            <label for="ContactFormBody-{{ section.id }}">Message</label>
            <textarea id="ContactFormBody-{{ section.id }}" class="field" name="contact[body]" required>{{ form.body }}</textarea>
          </div>

          <button type="submit" class="btn btn--primary">{{ section.settings.button_label }}</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>
