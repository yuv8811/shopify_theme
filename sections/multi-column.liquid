<style>

.multi-column { padding: 50px 20px; }
.multi-column__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
  margin-top: 35px;
}
.multi-column__item {
  padding: 30px;
  background: #fafafa;
  border-radius: 6px;
}
.multi-column__item h3 { margin-bottom: 10px; }
.multi-column__item p { color: #555; }

</style>


<div class="multi-column page-width">
  <h2 class="text-center">{{ section.settings.title }}</h2>
  <div class="multi-column__grid">
    <div class="multi-column__item text-center">
      <h3>Premium Design</h3>
      <p>Beautiful, minimal layouts designed to wow and perform.</p>
    </div>
    <div class="multi-column__item text-center">
      <h3>Eco-Friendly</h3>
      <p>100% sustainable materials sourced globally.</p>
    </div>
    <div class="multi-column__item text-center">
      <h3>Fast Shipping</h3>
      <p>Get your purchases in 2-3 business days worldwide.</p>
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Multi Column Features",
  "tag": "section",
  "class": "shopify-section-multi-column",
  "settings": [
  {
    "type": "text",
    "id": "title",
    "default": "Core Features",
    "label": "Section Heading"
  }
],
  "presets": [
    {
      "name": "Multi Column Features"
    }
  ]
}
{% endschema %}
