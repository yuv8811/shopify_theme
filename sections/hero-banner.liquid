<style>

.hero-banner {
  position: relative;
  height: 500px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f7f7;
}
.hero-banner__bg {
  position: absolute;
  top:0; left:0; width:100%; height:100%;
  object-fit: cover;
  z-index: 1;
}
.hero-banner__placeholder {
  position: absolute;
  top:0; left:0; width:100%; height:100%;
  background: linear-gradient(135deg, #a8c0ff, #3f2b96);
  z-index: 1;
}
.hero-banner__content {
  position: relative;
  z-index: 2;
  color: #ffffff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.2);
  max-width: 650px;
  padding: 20px;
}
.hero-banner__title {
  font-size: 40px;
  margin-bottom: 20px;
  color: #ffffff;
}
.hero-banner__text {
  font-size: 18px;
  margin-bottom: 30px;
}

</style>


<div class="hero-banner">
  {% if section.settings.image %}
    <img src="{{ section.settings.image | image_url: width: 1600 }}" alt="{{ section.settings.heading }}" class="hero-banner__bg" loading="lazy" width="1600" height="600">
  {% else %}
    <div class="hero-banner__placeholder"></div>
  {% endif %}
  <div class="hero-banner__content text-center">
    <div class="page-width">
      <h1 class="hero-banner__title">{{ section.settings.heading }}</h1>
      <p class="hero-banner__text">{{ section.settings.text }}</p>
      {% if section.settings.btn_label != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="btn btn--primary">{{ section.settings.btn_label }}</a>
      {% endif %}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "shopify-section-hero-banner",
  "settings": [
  {
    "type": "image_picker",
    "id": "image",
    "label": "Banner Image"
  },
  {
    "type": "text",
    "id": "heading",
    "default": "Modern Premium Theme",
    "label": "Heading"
  },
  {
    "type": "text",
    "id": "text",
    "default": "Discover our sleek products designed for lifestyle.",
    "label": "Description"
  },
  {
    "type": "text",
    "id": "btn_label",
    "default": "Shop Now",
    "label": "Button Label"
  },
  {
    "type": "url",
    "id": "btn_link",
    "label": "Button Link"
  }
],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
