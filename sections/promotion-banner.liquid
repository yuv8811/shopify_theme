<style>

.promotion-banner { padding: 60px 20px; color: #ffffff; }
.promotion-banner h2 { font-size: 32px; color: #ffffff; }
.promotion-banner p { font-size: 18px; margin-bottom: 20px; }

</style>


<div class="promotion-banner text-center" style="background: linear-gradient(135deg, #FF512F 0%, #DD2476 100%);">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    <a href="#" class="btn btn--secondary" style="border-color:#fff; color:#fff;">Shop Clearance</a>
  </div>
</div>


{% schema %}
{
  "name": "Promotion Banner",
  "tag": "section",
  "class": "shopify-section-promotion-banner",
  "settings": [
  {
    "type": "text",
    "id": "heading",
    "default": "Holiday Clearance Sale",
    "label": "Heading"
  },
  {
    "type": "text",
    "id": "subheading",
    "default": "Up to 50% Off Everything",
    "label": "Subheading"
  }
],
  "presets": [
    {
      "name": "Promotion Banner"
    }
  ]
}
{% endschema %}
