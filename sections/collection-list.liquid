  gap: 20px;
  margin-top: 30px;
}
.collection-list__card {
  text-align: center;
}
.collection-list__img-wrapper {
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 6px;
  background: #f7f7f7;
  margin-bottom: 10px;
}
.collection-list__img-wrapper img {
  width:100%; height:100%; object-fit: cover;
  transition: transform 0.3s;
}
.collection-list__img-wrapper:hover img {
  transform: scale(1.05);
}
.collection-list__img-placeholder {
  width:100%; height:100%;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
}
.collection-list__title {
  font-size: 16px;
  font-weight: 600;
  color: #111;
}

</style>


