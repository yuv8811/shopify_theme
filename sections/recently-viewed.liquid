<style>

.recently-viewed { padding: 40px 20px; }

</style>


<div class="recently-viewed page-width" id="RecentlyViewedSection">
  <h2>{{ section.settings.heading }}</h2>
  <div class="product-grid" id="RecentlyViewedGrid">
    <!-- Loaded dynamically via JS -->
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Basic Mock recently viewed simulation
    const grid = document.getElementById('RecentlyViewedGrid');
    if (grid) {
      const mockItems = [
        { title: 'Premium Leather Boots', price: '$120.00', image: 'https://picsum.photos/300/300?random=10' },
        { title: 'Minimalist Wristwatch', price: '$85.00', image: 'https://picsum.photos/300/300?random=11' }
      ];
      mockItems.forEach(item => {
        const card = document.createElement('div');
        card.className = 'product-card';
        card.innerHTML = `
          <a href="#">
            <div class="product-card__image-wrapper">
              <img src="${item.image}" alt="${item.title}" loading="lazy" width="300" height="300" style="width:100%; height:100%; object-fit:cover;">
            </div>
            <h3 class="product-card__title">${item.title}</h3>
            <div class="product-card__price">${item.price}</div>
          </a>
        `;
        grid.appendChild(card);
      });
    }
  });
</script>


{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "class": "shopify-section-recently-viewed",
  "settings": [
  {
    "type": "text",
    "id": "heading",
    "default": "Recently Viewed",
    "label": "Heading"
  }
],
  "presets": [
    {
      "name": "Recently Viewed Products"
    }
  ]
}
{% endschema %}
