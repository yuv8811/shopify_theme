<style>

.related-posts { padding: 40px 20px; border-top:1px solid #eee; }

</style>


<div class="related-posts page-width">
  <h3>Keep Reading</h3>
  <div class="blog-grid" style="margin-top:20px;">
    {% for i in (1..3) %}
      <div class="article-card">
        <a href="#">
          <div class="article-card__info" style="padding:20px;">
            <h4>Journal Entry Recap {{ i }}</h4>
            <span style="font-size:12px; color:#888;">June 16, 2026</span>
          </div>
        </a>
      </div>
    {% endfor %}
  </div>
</div>


{% schema %}
{
  "name": "Related Blog Posts",
  "tag": "section",
  "class": "shopify-section-related-posts",
  "settings": [],
  "presets": [
    {
      "name": "Related Blog Posts"
    }
  ]
}
{% endschema %}
