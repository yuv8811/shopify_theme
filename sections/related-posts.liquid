<section class="section">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="related-posts__grid" style="--columns: {{ section.settings.columns_desktop }};">
      {% assign posts_rendered = 0 %}
      {% for related_article in blog.articles %}
        {% if related_article.id != article.id and posts_rendered < section.settings.posts_to_show %}
          {% render 'article-card', article: related_article %}
          {% assign posts_rendered = posts_rendered | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related Blog Posts",
  "tag": "section",
  "class": "shopify-section-related-posts",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Continue reading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related stories"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Related Blog Posts"
    }
  ]
}
{% endschema %}
