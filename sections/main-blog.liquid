<section class="section">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ blog.title }}</h1>
      {% if section.settings.text != blank %}
        <p class="muted">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    {% paginate blog.articles by section.settings.articles_per_page %}
      {% if blog.articles_count > 0 %}
        <div class="article-grid" style="--columns: {{ section.settings.columns_desktop }};">
          {% for article in blog.articles %}
            {% render 'article-card', article: article %}
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="pagination" aria-label="Pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a class="page" href="{{ part.url }}">{{ part.title }}</a>
              {% else %}
                <span class="page{% if part.title == paginate.current_page %} current{% endif %}">{{ part.title }}</span>
              {% endif %}
            {% endfor %}
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </nav>
        {% endif %}
      {% else %}
        <div class="empty-state">
          <h2>No articles yet</h2>
          <p>Publish articles to start building organic discovery and editorial depth.</p>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main Blog",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editorial"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Keep blog templates clean, readable, and indexable so content can support both brand and SEO goals."
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Main Blog"
    }
  ]
}
{% endschema %}
