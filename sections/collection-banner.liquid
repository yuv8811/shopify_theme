<section class="section">
  <div class="page-width">
    <div class="collection-banner__shell">
      <div class="collection-banner__content">
        {% if section.settings.show_breadcrumbs %}
          <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href="{{ routes.root_url }}">Home</a>
            <span>/</span>
            <span>{{ collection.title }}</span>
          </nav>
        {% endif %}

        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h1>{{ collection.title }}</h1>

        {% if section.settings.show_description and collection.description != blank %}
          <div class="rte">{{ collection.description }}</div>
        {% endif %}
      </div>

      {% if section.settings.show_image and collection.featured_image != blank %}
        <div class="collection-banner__image">
          {{
            collection.featured_image
            | image_url: width: 1600
            | image_tag:
              widths: '480,720,960,1200,1600',
              sizes: '(min-width: 750px) 40vw, 100vw',
              loading: 'eager',
              alt: collection.title | escape
          }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "class": "shopify-section-collection-banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show collection image",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
