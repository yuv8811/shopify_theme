{% liquid
  assign source_collection = collection | default: product.collections.first
%}

{% if source_collection != blank and source_collection.products_count > 1 %}
  <section class="section">
    <div class="page-width">
      <div class="section-header">
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <div class="product-grid" style="--columns: {{ section.settings.columns_desktop }};">
        {% assign related_count = 0 %}
        {% for related_product in source_collection.products %}
          {% if related_product.id != product.id and related_count < section.settings.products_to_show %}
            {% render 'product-card', product: related_product, show_vendor: section.settings.show_vendor, show_secondary_image: true %}
            {% assign related_count = related_count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Related Products Grid",
  "tag": "section",
  "class": "shopify-section-related-products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "You may also like"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More from this collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Related Products Grid"
    }
  ]
}
{% endschema %}
