<section class="section">
  <div class="page-width">
    <div class="search-shell">
      <div class="section-header">
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        <h1>{{ section.settings.heading }}</h1>
      </div>

      <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
        <input type="hidden" name="type" value="product,article,page,collection">
        <div class="search-form__row">
          <input class="field" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.placeholder }}">
          <button class="btn btn--primary" type="submit">{{ section.settings.button_label }}</button>
        </div>
      </form>

      {% if search.performed %}
        <div class="search-results__heading">
          <h2>Results for "{{ search.terms }}"</h2>
          <p class="muted">{{ search.results_count }} matches</p>
        </div>

        {% paginate search.results by section.settings.results_per_page %}
          {% if search.results_count > 0 %}
            <div class="search-grid" style="--columns: {{ section.settings.columns_desktop }};">
              {% for item in search.results %}
                {% case item.object_type %}
                  {% when 'product' %}
                    {% render 'product-card', product: item, show_vendor: section.settings.show_vendor, show_secondary_image: true %}
                  {% when 'article' %}
                    {% render 'article-card', article: item %}
                  {% else %}
                    <article class="search-card">
                      <div class="search-card__content">
                        <p class="search-card__meta">{{ item.object_type | capitalize }}</p>
                        <h3 class="search-card__title"><a href="{{ item.url }}">{{ item.title }}</a></h3>
                        {% if item.content != blank %}
                          <p class="muted">{{ item.content | strip_html | truncatewords: 24 }}</p>
                        {% endif %}
                      </div>
                    </article>
                {% endcase %}
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <nav class="pagination" aria-label="Pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}">Previous</a>
                {% endif %}
                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a class="page" href="{{ part.url }}">{{ part.title }}</a>
                  {% else %}
                    <span class="page{% if part.title == paginate.current_page %} current{% endif %}">{{ part.title }}</span>
                  {% endif %}
                {% endfor %}
                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}">Next</a>
                {% endif %}
              </nav>
            {% endif %}
          {% else %}
            <div class="empty-state">
              <h2>No results found</h2>
              <p>Try broader keywords, product types, or collection names.</p>
            </div>
          {% endif %}
        {% endpaginate %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Search",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Search the store"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find products, pages, and articles"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "Search for products, topics, or collections"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Search"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 6,
      "max": 24,
      "step": 6,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor on product results",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Main Search"
    }
  ]
}
{% endschema %}
