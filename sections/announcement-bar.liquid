<div class="announcement-bar" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="page-width">
    <div class="announcement-bar__inner">
      <p>{{ section.settings.text }}</p>
      {% if section.settings.link_label != blank and section.settings.link != blank %}
        <a href="{{ section.settings.link }}" class="btn btn--ghost">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "shopify-section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "Free shipping thresholds, campaign windows, and trust messaging belong here.",
      "label": "Announcement text"
    },
    {
      "type": "text",
      "id": "link_label",
      "default": "Learn more",
      "label": "Link label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#163534",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#ffffff",
      "label": "Text color"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
