<style>

.newsletter { padding: 60px 20px; max-width: 600px; }
.newsletter__form { display: flex; gap: 10px; margin-top: 20px; justify-content: center; }
.newsletter__input { padding: 12px; border: 1px solid #ccc; border-radius: 4px; width: 60%; font-size: 15px; }

</style>


<div class="newsletter text-center page-width">
  <h2>{{ section.settings.heading }}</h2>
  <p>Signup for deals, new arrivals, and updates.</p>
  <form action="/contact#contact_form" method="post" class="newsletter__form">
    <input type="email" placeholder="Your email address" required name="contact[email]" class="newsletter__input">
    <button type="submit" class="btn btn--primary">Subscribe</button>
  </form>
</div>


{% schema %}
{
  "name": "Newsletter Signup",
  "tag": "section",
  "class": "shopify-section-newsletter",
  "settings": [
  {
    "type": "text",
    "id": "heading",
    "default": "Subscribe to our newsletter",
    "label": "Heading"
  }
],
  "presets": [
    {
      "name": "Newsletter Signup"
    }
  ]
}
{% endschema %}
