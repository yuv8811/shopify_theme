<section class="section">
  <div class="page-width">
    <div class="page-section__inner">
      {% if section.settings.show_breadcrumbs %}
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span>/</span>
          <span>{{ page.title }}</span>
        </nav>
      {% endif %}

      <article class="page-shell"{% if section.settings.narrow_width %} style="max-width: 52rem;"{% endif %}>
        {% if section.settings.show_title %}
          <h1>{{ page.title }}</h1>
        {% endif %}
        <div class="page-content rte">{{ page.content }}</div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "narrow_width",
      "label": "Use narrow content width",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Main Page"
    }
  ]
}
{% endschema %}
