<style>

.team-members { padding: 40px 20px; }
.team-members__grid { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; margin-top: 30px; }
.team-members__avatar { width: 120px; height: 120px; border-radius: 50%; background:#eaeaea; margin: 0 auto 15px; }

</style>


<div class="team-members page-width">
  <h2 class="text-center">Meet Our Team</h2>
  <div class="team-members__grid">
    <div class="team-members__member text-center">
      <div class="team-members__avatar"></div>
      <h4>David Carter</h4>
      <p style="color:#666; font-size:14px;">Co-Founder & Creative Director</p>
    </div>
    <div class="team-members__member text-center">
      <div class="team-members__avatar"></div>
      <h4>Elena Rostova</h4>
      <p style="color:#666; font-size:14px;">Head of Textile Sourcing</p>
    </div>
  </div>
</div>


