<section class="section">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              <article class="cart-item">
                <div class="cart-item__image">
                  <a href="{{ item.url }}">
                    {% if item.image %}
                      {{
                        item.image
                        | image_url: width: 320
                        | image_tag:
                          widths: '120,180,240,320',
                          sizes: '8rem',
                          loading: 'lazy',
                          alt: item.product.title | escape
                      }}
                    {% endif %}
                  </a>
                </div>

                <div class="cart-item__meta">
                  <h2><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                  {% if item.variant.title != 'Default Title' %}
                    <p class="muted">{{ item.variant.title }}</p>
                  {% endif %}
                  <p class="muted">{{ item.final_price | money }}</p>
                  <a class="muted" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                </div>

                <div class="cart-item__meta">
                  <label class="visually-hidden" for="CartQuantity-{{ item.key }}">Quantity</label>
                  <div class="quantity-selector">
                    <button type="button" data-quantity-button="minus" aria-label="Decrease quantity">-</button>
                    <input id="CartQuantity-{{ item.key }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                    <button type="button" data-quantity-button="plus" aria-label="Increase quantity">+</button>
                  </div>
                  <strong>{{ item.final_line_price | money }}</strong>
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="cart-summary">
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>

            {% if section.settings.show_note %}
              <div class="product-form__group">
                <label for="CartNote-{{ section.id }}">Order note</label>
                <textarea id="CartNote-{{ section.id }}" class="field" name="note">{{ cart.note }}</textarea>
              </div>
            {% endif %}

            <p class="muted">{{ section.settings.helper_text }}</p>

            <div class="cart-actions">
              <button class="btn btn--secondary" type="submit" name="update">Update cart</button>
              <button class="btn btn--primary" type="submit" name="checkout">Checkout</button>
            </div>
          </aside>
        </div>
      </form>
    {% else %}
      <div class="empty-state">
        <h2>Your cart is empty</h2>
        <p>Add products from your featured collections or search to begin checkout.</p>
        <a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">Browse products</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Checkout flow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    },
    {
      "type": "textarea",
      "id": "helper_text",
      "label": "Helper text",
      "default": "Taxes and shipping are calculated at checkout."
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show order note",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}
