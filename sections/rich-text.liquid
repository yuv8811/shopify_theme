<section class="section">
  <div class="page-width">
    <div class="page-shell"{% if section.settings.alignment == 'center' %} style="text-align:center; max-width: 52rem; margin-inline:auto;"{% else %} style="max-width: 52rem;"{% endif %}>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2>{{ section.settings.heading }}</h2>
      <div class="rte">{{ section.settings.text }}</div>
      {% if section.settings.button_label != blank %}
        <div class="button-row"{% if section.settings.alignment == 'center' %} style="justify-content:center;"{% endif %}>
          <a class="btn btn--secondary" href="{{ section.settings.button_link | default: routes.root_url }}">{{ section.settings.button_label }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "class": "shopify-section-rich-text",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Editorial flexibility",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Tell a stronger brand story",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Use rich text for editorial sections, value props, campaign copy, or conversion-supporting FAQ intros.</p>",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Rich Text"
    }
  ]
}
{% endschema %}
